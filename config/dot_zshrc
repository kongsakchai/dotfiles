# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Direnv
eval "$(direnv hook zsh)"

# fzf
source <(fzf --zsh)

# Workspaces
export WORKSPACE=$HOME/kong
source $WORKSPACE/workspaces/.config

# Languages
## Go
export GOROOT=~/goroot
export GOPATH=~/go
export GOBIN=~/go/bin
export PATH=$PATH:$GOROOT/bin:$GOBIN

## JAVA
alias java21="export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home ; java -version"

## Node.js
eval "$(fnm env --use-on-cd --shell zsh)"

## bun
export BUN_INSTALL=$HOME/.bun
export PATH=$PATH:$BUN_INSTALL/bin

# podman
export DOCKER_HOST=unix:///var/folders/vw/45hwmvrn1c3d2y4_7jk63hlm0000gp/T/podman/podman-machine-default-api.sock

# starship
eval "$(starship init zsh)"
